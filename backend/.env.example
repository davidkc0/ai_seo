# Illusion - Environment Variables
# Copy this to .env and fill in your values

# Security
SECRET_KEY=your-secret-key-here-change-this-in-production
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"

# OpenRouter — one key, routes to Claude + GPT + Gemini + Perplexity.
# Used by monitor.py for the LLM scan step (4 providers × 6-8 queries per scan).
# https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Anthropic — used DIRECTLY by recommendations.py to generate the per-scan
# SEO summary (fed LLM scan data + Google AI Overview citations).
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6

# SerpAPI — scrapes Google AI Overview for the primary category query each scan.
# Free tier: 100 searches/mo (enough for ~50-100 scans since only ~36% of
# queries actually return an AI Overview). https://serpapi.com/manage-api-key
SERPAPI_API_KEY=your-serpapi-key-here

# Resend (Email)
# Get your free key at https://resend.com
RESEND_API_KEY=re_your_key_here
RESEND_FROM_EMAIL=noreply@contact.illusion.ai

# Stripe (Payments)
# Get your keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_STARTER_PRICE_ID=price_your_starter_price_id
STRIPE_GROWTH_PRICE_ID=price_your_growth_price_id

# App Settings
APP_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
DATABASE_URL=sqlite:///./ai_mention_tracker.db
