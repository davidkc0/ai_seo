    posthog.init('phc_u5DvvCpYTgmqsAqvKt3NP57FVcWT2A8ZE66i8dvNuqBD', {
      api_host: 'https://us.i.posthog.com',
      ui_host: 'https://us.posthog.com',
      persistence: 'memory',
      capture_pageview: true,
      capture_pageleave: true,
      autocapture: true,
    });
  </script>
</head>
<body>
  <!-- Nav -->
  <nav class="blog-nav">
    <a class="logo" href="https://www.illusion.ai/">
      <img src="/blog/illusion_logo.svg" alt="Illusion" />
      <div class="logo-divider"></div>
      <span class="logo-label">Blog</span>
    </a>
    <div class="blog-nav-links">
      <a href="https://www.illusion.ai/#features">Features</a>
      <a href="https://www.illusion.ai/#pricing">Pricing</a>
      <a href="/blog">Articles</a>
      <a href="https://www.illusion.ai/register" class="btn-primary-sm">Start free trial</a>
    </div>
  </nav>

  <slot />

  <!-- Footer -->
  <footer class="blog-footer">
    <div>&copy; 2026 Illusion</div>
    <div class="blog-footer-links">
      <a href="https://www.illusion.ai/">Home</a>
      <a href="/blog">Blog</a>
      <a href="https://www.illusion.ai/login">Log in</a>
    </div>
  </footer>
</body>
</html>
