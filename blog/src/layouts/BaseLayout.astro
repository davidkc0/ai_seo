---
interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonical?: string;
  slug?: string;
  tags?: string[];
}

const { title, description, ogImage, canonical, slug, tags } = Astro.props;
const resolvedOG = ogImage || 'https://www.illusion.ai/OG.png';
const resolvedCanonical = canonical || Astro.url.href;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={resolvedCanonical} />
  <meta name="robots" content="index, follow" />

  <!-- Icons -->
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <meta name="theme-color" content="#10b981" />

  <!-- OG -->
  <meta property="og:type" content="article" />
  <meta property="og:site_name" content="Illusion" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={resolvedCanonical} />
  <meta property="og:image" content={resolvedOG} />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={resolvedOG} />

  <!-- PostHog (cookieless — no cookie banner needed) -->
  <script is:inline>
