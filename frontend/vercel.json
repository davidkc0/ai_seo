{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/blog/:match*", "destination": "https://ai-seo-6jvg.vercel.app/blog/:match*" },
    { "source": "/blog", "destination": "https://ai-seo-6jvg.vercel.app/blog" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
